<div class="top-row ps-3 navbar navbar-dark bg-dark">
    <div class="container-fluid">

        
        <a class="navbar-brand" href="">
            InsightMail AI
        </a>

        <button title="Navigation menu"
                class="navbar-toggler"
                @onclick="ToggleNavMenu">

            <span class="navbar-toggler-icon"></span>

        </button>

    </div>
    

</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">

    
    <nav class="flex-column">

        <!-- Home -->
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href=""
                     Match="NavLinkMatch.All">

                <span class="bi bi-house-door-fill"
                      aria-hidden="true"></span>

                Home

            </NavLink>

        </div>

        <!-- Emails Dashboard -->
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="emails">

                <span class="bi bi-envelope-fill"
                      aria-hidden="true"></span>

                Emails

            </NavLink>

        </div>

        <!-- Upload Email -->
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="upload">

                <span class="bi bi-upload"
                      aria-hidden="true"></span>

                Upload Email

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="tasks">

                <span class="bi bi-task"
                      aria-hidden="true"></span>

               Tasks

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="ask">

                <span class="bi bi-chat"
                      aria-hidden="true"></span>

               Chat

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="search">

                <span class="bi bi-chat"
                      aria-hidden="true"></span>
Search

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="reply-analytics">

                <span class="bi bi-chat"
                      aria-hidden="true"></span>
Reply Analytics

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="summary-analytics">

                <span class="bi bi-chat"
                      aria-hidden="true"></span>
Summary Analytics

            </NavLink>

        </div>
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="thread-summary">

                <span class="bi bi-chat"
                      aria-hidden="true"></span>
Thread Summary

            </NavLink>

        </div>

        <!-- Email Statistics -->
        <div class="nav-item px-3">

            <NavLink class="nav-link"
                     href="stats">

                <span class="bi bi-bar-chart-fill"
                      aria-hidden="true"></span>

                Email Statistics

            </NavLink>

        </div>

    </nav>
    

</div>

@code {


private bool collapseNavMenu = true;

    private string? NavMenuCssClass
        => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }


}
