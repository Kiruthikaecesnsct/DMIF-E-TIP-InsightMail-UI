@page "/emails/{Id}"
@using InsightMailUI.Models
@using MudBlazor
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large">

@if (email == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{

    <!-- EMAIL CARD -->

    <MudCard Class="mb-4">

        <MudCardHeader>
            <MudText Typo="Typo.h5">@email.Subject</MudText>

            <MudChip T="String"
                     Color="@GetCategoryColor(email.Category)"
                     Size="Size.Small"
                     Class="ml-2">
                @email.Category
            </MudChip>
        </MudCardHeader>

        <MudCardContent>

            <MudText><b>From:</b> @email.Sender</MudText>
            <MudText><b>Date:</b> @email.ReceivedDate</MudText>
            <MudText><b>Priority:</b> @email.Priority/10</MudText>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.body1">
                @email.Body
            </MudText>

            @if (!string.IsNullOrEmpty(email.ClassificationReasoning))
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">

                    <MudText Typo="Typo.subtitle2">
                        AI Classification Reasoning
                    </MudText>

                    <MudText Typo="Typo.body2">
                        @email.ClassificationReasoning
                    </MudText>

                    <MudText Typo="Typo.caption">
                        Confidence:
                        @email.ClassificationConfidence?.ToString("P0")
                    </MudText>

                </MudAlert>
            }

        </MudCardContent>

    </MudCard>


    <!-- ACTION ITEMS -->

    <MudCard>

        <MudCardHeader>

            <MudText Typo="Typo.h6">

                <MudIcon Icon="@Icons.Material.Filled.Task" />

                Extracted Action Items

            </MudText>

        </MudCardHeader>

        <MudCardContent>

            @if (actionItems == null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (!actionItems.Any())
            {
                <MudAlert Severity="Severity.Info">
                    No action items found
                </MudAlert>
            }
            else
            {
                @foreach (var item in actionItems)
                {
                    <ActionItemCard Item="@item"
                                    OnStatusChanged="LoadActionItems" />
                }
            }

        </MudCardContent>

    </MudCard>

}

</MudContainer>


@code {

    [Parameter] public string Id { get; set; } = "";

    private Email? email;

    private List<ActionItem>? actionItems;

    protected override async Task OnInitializedAsync()
    {
        email = await Http.GetFromJsonAsync<Email>($"api/v1/emails/{Id}");

        await LoadActionItems();
    }

    private async Task LoadActionItems()
    {
        try
        {
            actionItems = await Http.GetFromJsonAsync<List<ActionItem>>
            ($"api/v1/actionitems/email/{Id}");
        }
        catch
        {
            actionItems = new List<ActionItem>();
        }

        StateHasChanged();
    }

    private Color GetCategoryColor(string? category)
    {
        return category switch
        {
            "Urgent" => Color.Error,
            "Action Required" => Color.Warning,
            "FYI" => Color.Info,
            "Newsletter" => Color.Success,
            _ => Color.Default
        };
    }

}