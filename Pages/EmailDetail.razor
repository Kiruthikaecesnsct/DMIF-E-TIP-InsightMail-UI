@page "/emails/{Id}"
@using InsightMailUI.Models
@using MudBlazor
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large">
    @if (email == null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <!-- EMAIL CARD -->
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">@email.Subject</MudText>
                    <MudChip T="string"
                             Color="@GetCategoryColor(email.Category)"
                             Size="Size.Small"
                             Class="ml-2">
                        @email.Category
                    </MudChip>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText><b>From:</b> @email.Sender</MudText>
                <MudText><b>Date:</b> @email.ReceivedDate</MudText>
                <MudText><b>Priority:</b> @email.Priority/10</MudText>
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.body1">@email.Body</MudText>

                @if (!string.IsNullOrEmpty(email.ClassificationReasoning))
                {
                    <MudAlert Severity="Severity.Info" Class="mt-4">
                        <MudText Typo="Typo.subtitle2">AI Classification Reasoning</MudText>
                        <MudText Typo="Typo.body2">@email.ClassificationReasoning</MudText>
                        <MudText Typo="Typo.caption">
                            Confidence: @email.ClassificationConfidence?.ToString("P0")
                        </MudText>
                    </MudAlert>
                }
            </MudCardContent>
        </MudCard>

        <!-- FEATURE 1 + 2: Tone selector, length slider, generate button -->
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-2" />
                        Reply Generator
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect @bind-Value="selectedTone"
                                   Label="Tone"
                                   Variant="Variant.Outlined"
                                   FullWidth="true">
                            <MudSelectItem Value="@("Professional")">Professional</MudSelectItem>
                            <MudSelectItem Value="@("Friendly")">Friendly</MudSelectItem>
                            <MudSelectItem Value="@("Formal")">Formal</MudSelectItem>
                            <MudSelectItem Value="@("Casual")">Casual</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.body2" Class="mb-1">
                            Max Words: <b>@maxWords</b>
                        </MudText>
                        <MudSlider @bind-Value="maxWords"
                                   Min="50"
                                   Max="500"
                                   Step="50"
                                   Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="GenerateReplies"
                           Disabled="isGenerating"
                           Class="ml-2 mb-2">
                    @if (isGenerating)
                    {
                        <MudProgressCircular Size="Size.Small"
                                             Indeterminate="true"
                                             Class="mr-2" />
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Generate Reply</span>
                    }
                </MudButton>
            </MudCardActions>
        </MudCard>

        <!-- REPLY OPTIONS -->
        @if (replyResponse?.Replies?.Any() == true)
        {
            <MudCard Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Reply" Class="mr-2" />
                            AI-Generated Reply Options
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Generated at @replyResponse?.GeneratedAt.ToLocalTime().ToString("hh:mm tt")
                            · Tone: @selectedTone · Max @maxWords words
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        @foreach (var reply in replyResponse?.Replies ?? new())
                        {
                            <MudItem xs="12" md="4">
                                <MudCard Outlined="true" Class="h-100">
                                    <MudCardHeader>
                                        <CardHeaderContent>
                                            <MudChip T="string"
                                                     Color="@GetReplyTypeColor(reply.Type)"
                                                     Size="Size.Small">
                                                @GetReplyTypeLabel(reply.Type)
                                            </MudChip>
                                        </CardHeaderContent>
                                        <CardHeaderActions>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @reply.Confidence.ToString("P0")
                                            </MudText>
                                        </CardHeaderActions>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudTextField @bind-Value="reply.Body"
                                                      Lines="8"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true"
                                                      Label="Edit before sending" />
                                    </MudCardContent>
                                    <MudCardActions>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                                   OnClick="@(() => CopyAndTrack(reply))">
                                            Copy
                                        </MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   StartIcon="@Icons.Material.Filled.Refresh"
                                                   OnClick="GenerateReplies">
                                            Regenerate
                                        </MudButton>
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }

        <!-- ACTION ITEMS -->
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Task" />
                    Extracted Action Items
                </MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (actionItems == null)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else if (!actionItems.Any())
                {
                    <MudAlert Severity="Severity.Info">No action items found</MudAlert>
                }
                else
                {
                    @foreach (var item in actionItems)
                    {
                        <ActionItemCard Item="@item" OnStatusChanged="LoadActionItems" />
                    }
                }
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public string Id { get; set; } = "";

    private Email? email;
    private List<ActionItem>? actionItems;
    private ReplyResponse? replyResponse;
    private bool isGenerating = false;

    // Feature 1: Tone
    private string selectedTone = "Professional";

    // Feature 2: Length
    private int maxWords = 300;

    // Track original bodies for edit distance (type → original body)
    private Dictionary<string, string> originalBodies = new();

    protected override async Task OnInitializedAsync()
    {
        email = await Http.GetFromJsonAsync<Email>($"api/v1/emails/{Id}");
        await LoadActionItems();
    }

    private async Task LoadActionItems()
    {
        try
        {
            actionItems = await Http.GetFromJsonAsync<List<ActionItem>>
                ($"api/v1/actionitems/email/{Id}");
        }
        catch
        {
            actionItems = new List<ActionItem>();
        }
        StateHasChanged();
    }

    private async Task GenerateReplies()
    {
        isGenerating = true;
        replyResponse = null;
        originalBodies.Clear();
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync(
                $"api/v1/emails/generate-reply/{Id}",
                new { PreferredTone = selectedTone, MaxLength = maxWords });

            if (response.IsSuccessStatusCode)
            {
                replyResponse = await response.Content
                    .ReadFromJsonAsync<ReplyResponse>();

                // Store originals for edit distance tracking
                foreach (var reply in replyResponse?.Replies ?? new())
                    originalBodies[reply.Type] = reply.Body;

                Snackbar.Add("Replies generated!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to generate replies", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task CopyAndTrack(EmailReply reply)
    {
        // Copy to clipboard
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", reply.Body);
        Snackbar.Add("Copied to clipboard!", Severity.Success);

        // Track analytics
        try
        {
            var original = originalBodies.GetValueOrDefault(reply.Type, reply.Body);

            var entry = new ReplyAnalyticsEntry
            {
                EmailId = Id,
                SelectedType = reply.Type,
                OriginalBody = original,
                FinalBody = reply.Body,
                ToneUsed = selectedTone,
                MaxWordsUsed = maxWords
            };

            var response = await Http.PostAsJsonAsync(
                "api/v1/emails/reply-analytics", entry);

            if (response.IsSuccessStatusCode)
                Snackbar.Add("Analytics saved", Severity.Info);
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Analytics failed: {error}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Analytics error: {ex.Message}", Severity.Warning);
        }
    }

    private Color GetCategoryColor(string? category) => category switch
    {
        "Urgent" => Color.Error,
        "Action Required" => Color.Warning,
        "FYI" => Color.Info,
        "Newsletter" => Color.Success,
        _ => Color.Default
    };

    private Color GetReplyTypeColor(string? type) => type switch
    {
        "brief" => Color.Info,
        "detailed" => Color.Primary,
        "decline" => Color.Warning,
        _ => Color.Default
    };

    private string GetReplyTypeLabel(string? type) => type switch
    {
        "brief" => "Brief Reply",
        "detailed" => "Detailed Reply",
        "decline" => "Polite Decline",
        _ => type ?? "Reply"
    };
}